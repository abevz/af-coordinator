{
  "preToolUse": {
    "matcher": {
      "type": "any",
      "matchers": [
        {"type": "tool", "name": "Edit"},
        {"type": "tool", "name": "Write"},
        {"type": "tool", "name": "Bash"}
      ]
    },
    "command": "${PROJECT_DIR}/contrib/hooks/claude-code/check-lease.sh",
    "mode": "warn"
  }
}
